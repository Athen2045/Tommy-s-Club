<div class="brick-wall" style="opacity:0.6"></div>

<div class="gate-wrap" style="z-index:5">
    <!-- Tommy's neon sign (small) -->
    <div class="neon-sign-stack sm">
        <div class="neon-tommys">Tommy's</div>
        <div class="neon-club">CLUB</div>
    </div>

    <div class="gate-eyebrow" style="margin-top:-6px">— Request Access —</div>

    {{#if errorMessage}}
    <p class="gate-error" style="width:100%;max-width:360px">{{errorMessage}}</p>
    {{/if}}

    {{#if successMessage}}
    <div class="gate-form-box" style="text-align:center">
        <p class="gate-success">{{successMessage}}</p>
        <a href="/login" class="gate-btn mt-3">&#x25B8; ENTER TOMMY'S CLUB</a>
    </div>
    {{else}}

    <div class="gate-form-box">
        <form method="POST" action="/register" class="gate-form" id="registerForm">
            <input type="hidden" name="_csrf" value="{{csrfToken}}">

            <!-- Alias with random generator -->
            <div class="gate-field">
                <div class="gate-label-row">
                    <label class="gate-label" for="usernameInput">Username</label>
                    <button class="alias-random" id="genBtn" type="button" title="Suggest a username">Suggest one</button>
                </div>
                <input type="text" name="username" id="usernameInput" class="gate-input"
                    value="{{username}}" placeholder="neon_ghost" minlength="3" maxlength="32"
                    pattern="[a-zA-Z0-9_]{3,32}" autocomplete="username" required autofocus>
                <span class="gate-helper">3–32 letters, numbers, or underscores. Every username is unique.</span>
            </div>

            <div class="gate-field">
                <label class="gate-label" for="registerEmail">Email</label>
                <input type="email" name="email" id="registerEmail" class="gate-input"
                    value="{{email}}" placeholder="anon@member.club" autocomplete="email" required>
            </div>

            <div class="gate-field">
                <label class="gate-label" for="registerPassword">Create password</label>
                <input type="password" name="password" id="registerPassword" class="gate-input"
                    placeholder="8+ chars, uppercase, number, symbol" required minlength="8"
                    pattern="(?=.*[a-z])(?=.*[A-Z])(?=.*[0-9])(?=.*[^A-Za-z0-9]).{8,}"
                    title="Use at least 8 characters, including uppercase, lowercase, a number, and a symbol"
                    aria-describedby="passwordRequirements">
                <ul class="password-requirements" id="passwordRequirements" aria-label="Password requirements">
                    <li data-password-rule="length"><span class="password-rule-mark" aria-hidden="true"></span>At least 8 characters</li>
                    <li data-password-rule="uppercase"><span class="password-rule-mark" aria-hidden="true"></span>At least one uppercase letter</li>
                    <li data-password-rule="lowercase"><span class="password-rule-mark" aria-hidden="true"></span>At least one lowercase letter</li>
                    <li data-password-rule="number"><span class="password-rule-mark" aria-hidden="true"></span>At least one number</li>
                    <li data-password-rule="symbol"><span class="password-rule-mark" aria-hidden="true"></span>At least one symbol</li>
                </ul>
            </div>

            <div class="gate-field">
                <label class="gate-label" for="registerPasswordConfirm">Confirm password</label>
                <input type="password" name="password2" id="registerPasswordConfirm" class="gate-input"
                    placeholder="Repeat your password" required minlength="8" aria-describedby="passwordMatchStatus">
                <span class="password-match-status" id="passwordMatchStatus" aria-live="polite"></span>
            </div>

            <button type="submit" class="gate-btn">&#x25B8; JOIN TOMMY'S CLUB</button>
        </form>

        <p class="gate-switch mt-2">Already a member? <a href="/login">Enter</a></p>
    </div>

    {{/if}}
</div>

<script>
(function () {
    var adj  = ['Shadow','Cipher','Neon','Ghost','Phantom','Silent','Dark','Void','Echo','Mystic',
                'Stealth','Rogue','Onyx','Obsidian','Azure','Crimson','Silver','Veiled','Arcane','Lunar',
                'Ember','Frosted','Static','Hollow','Prism','Cobalt','Scarlet','Iron','Gilded','Ivory'];
    var noun = ['Wolf','Fox','Raven','Hawk','Serpent','Viper','Specter','Wraith','Oracle','Nexus',
                'Vector','Vertex','Nova','Drift','Pulse','Shade','Flux','Storm','Veil','Glitch',
                'Nomad','Cipher','Knight','Drifter','Signal','Myth','Edge','Shard','Crest','Bloom'];

    var genBtn = document.getElementById('genBtn');
    if (genBtn) {
        genBtn.addEventListener('click', function () {
            var a = adj[Math.floor(Math.random() * adj.length)];
            var n = noun[Math.floor(Math.random() * noun.length)];
            document.getElementById('usernameInput').value = a + n;
        });
    }

    var registerForm = document.getElementById('registerForm');
    var password = registerForm && registerForm.querySelector('input[name="password"]');
    var password2 = registerForm && registerForm.querySelector('input[name="password2"]');
    if (registerForm && password && password2) {
        var rules = {
            length: function (value) { return value.length >= 8; },
            uppercase: function (value) { return /[A-Z]/.test(value); },
            lowercase: function (value) { return /[a-z]/.test(value); },
            number: function (value) { return /[0-9]/.test(value); },
            symbol: function (value) { return /[^A-Za-z0-9]/.test(value); }
        };
        var matchStatus = document.getElementById('passwordMatchStatus');
        var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        function animateRule(item) {
            if (reduceMotion || !window.anime || !window.anime.animate) return;
            window.anime.animate(item, {
                scale: [0.96, 1],
                opacity: [0.65, 1],
                duration: 220,
                ease: 'out(3)'
            });
        }

        function updateRequirements() {
            document.querySelectorAll('[data-password-rule]').forEach(function (item) {
                var met = rules[item.dataset.passwordRule](password.value);
                var wasMet = item.classList.contains('is-met');
                item.classList.toggle('is-met', met);
                item.setAttribute('aria-label', (met ? 'Met: ' : 'Not met: ') + item.textContent.trim());
                if (met && !wasMet) animateRule(item);
            });
        }

        function confirmPassword() {
            var hasValue = password2.value.length > 0;
            var matches = password.value === password2.value;
            password2.setCustomValidity(!hasValue || matches ? '' : 'Passwords do not match');
            matchStatus.textContent = !hasValue ? '' : (matches ? 'Passwords match.' : 'Passwords do not match.');
            matchStatus.classList.toggle('is-match', hasValue && matches);
            matchStatus.classList.toggle('is-error', hasValue && !matches);
        }
        password.addEventListener('input', function () {
            updateRequirements();
            confirmPassword();
        });
        password2.addEventListener('input', confirmPassword);
        registerForm.addEventListener('submit', confirmPassword);
        updateRequirements();
    }

})();
</script>
