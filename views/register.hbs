<div class="gate-wrap">

    <div class="ctos-emblem-wrap">
        <div class="ctos-emblem ctos-emblem-sm">
            <svg class="ctos-outer-hex" viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
                <polygon points="60,4 110,32 110,88 60,116 10,88 10,32"
                    stroke="#00d4ff" stroke-width="1" stroke-dasharray="5 3" opacity="0.5"/>
            </svg>
            <svg class="ctos-inner-hex" viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
                <polygon points="60,20 96,42 96,78 60,100 24,78 24,42"
                    stroke="#00d4ff" stroke-width="1.5" opacity="0.3"/>
            </svg>
            <div class="ctos-scan-line"></div>
            <div class="ctos-glyph">C9</div>
            <div class="ctos-corner ctos-corner-tl"></div>
            <div class="ctos-corner ctos-corner-tr"></div>
            <div class="ctos-corner ctos-corner-bl"></div>
            <div class="ctos-corner ctos-corner-br"></div>
            <div class="ctos-hud-label">CLUB.9 · ACCESS</div>
        </div>
    </div>

    <!-- Form -->
    <div class="gate-form-wrap">

        {{#if errorMessage}}
        <p class="gate-error">{{errorMessage}}</p>
        {{/if}}

        {{#if successMessage}}
        <p class="gate-success">{{successMessage}}</p>
        <a href="/login" class="gate-btn mt-2">ENTER CLUB9</a>
        {{else}}

        <form method="POST" action="/register" class="gate-form" id="registerForm">

            <!-- Avatar picker -->
            <div class="gate-field">
                <label class="gate-label">ANONYMOUS IDENTITY</label>
                <div class="avatar-picker">
                    <label class="avatar-pick-option">
                        <input type="radio" name="default_avatar" value="m" checked>
                        <div class="avatar-pick-card">
                            <img src="/assets/avatar-anon-m.svg" alt="Anonymous Male">
                            <span>Shadow</span>
                        </div>
                    </label>
                    <label class="avatar-pick-option">
                        <input type="radio" name="default_avatar" value="f">
                        <div class="avatar-pick-card">
                            <img src="/assets/avatar-anon-f.svg" alt="Anonymous Female">
                            <span>Phantom</span>
                        </div>
                    </label>
                </div>
                <input type="hidden" name="avatar_url" id="avatarUrlInput" value="/assets/avatar-anon-m.svg">
            </div>

            <!-- Username with generator -->
            <div class="gate-field">
                <label class="gate-label">ALIAS</label>
                <div class="gate-input-row">
                    <input type="text" name="username" id="usernameInput" class="gate-input"
                        value="{{username}}" placeholder="your handle" required autofocus>
                    <button type="button" class="gate-gen-btn" id="genBtn" title="Generate random alias">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                            <polyline points="1 4 1 10 7 10"></polyline>
                            <polyline points="23 20 23 14 17 14"></polyline>
                            <path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 0 1 3.51 15"></path>
                        </svg>
                    </button>
                </div>
            </div>

            <div class="gate-field">
                <label class="gate-label">EMAIL</label>
                <input type="email" name="email" class="gate-input"
                    value="{{email}}" placeholder="your@email.com" required>
            </div>
            <div class="gate-field">
                <label class="gate-label">PASSWORD</label>
                <input type="password" name="password" class="gate-input"
                    placeholder="Min. 6 characters" required minlength="6">
            </div>
            <div class="gate-field">
                <label class="gate-label">CONFIRM PASSWORD</label>
                <input type="password" name="password2" class="gate-input"
                    placeholder="••••••••" required>
            </div>
            <button type="submit" class="gate-btn">JOIN CLUB9</button>
        </form>

        <p class="gate-switch">
            Already a member? <a href="/login">Enter</a>
        </p>

        {{/if}}
    </div>

</div>

<script>
(function () {
    const adj = ['Shadow','Cipher','Neon','Ghost','Phantom','Silent','Dark','Void','Echo','Mystic',
                 'Stealth','Rogue','Onyx','Obsidian','Azure','Crimson','Silver','Veiled','Arcane','Lunar',
                 'Ember','Frosted','Static','Hollow','Prism','Cobalt','Scarlet','Iron','Gilded','Ivory'];
    const noun = ['Wolf','Fox','Raven','Hawk','Serpent','Viper','Specter','Wraith','Oracle','Nexus',
                  'Vector','Vertex','Nova','Drift','Pulse','Shade','Flux','Storm','Veil','Glitch',
                  'Nomad','Cipher','Knight','Drifter','Signal','Myth','Edge','Shard','Crest','Bloom'];

    document.getElementById('genBtn').addEventListener('click', function () {
        const a = adj[Math.floor(Math.random() * adj.length)];
        const n = noun[Math.floor(Math.random() * noun.length)];
        document.getElementById('usernameInput').value = a + n;
    });

    document.querySelectorAll('input[name="default_avatar"]').forEach(function (radio) {
        radio.addEventListener('change', function () {
            document.getElementById('avatarUrlInput').value =
                this.value === 'f' ? '/assets/avatar-anon-f.svg' : '/assets/avatar-anon-m.svg';
        });
    });
})();
</script>
