<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="theme-color" content="#f4eedf">
    <title>{{#if title}}{{title}} — {{/if}}Tommy's Club</title>
    <meta name="csrf-token" content="{{csrfToken}}">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Libre+Bodoni:ital,wght@0,400;0,500;0,600;0,700;1,500&family=Press+Start+2P&family=Public+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/editorial.css">
    <script src="/js/forms.js" defer></script>
</head>
<body class="editorial-body">
<a class="skip-link" href="#main-content">Skip to content</a>

<div class="app-shell">
    <aside class="app-rail" aria-label="Primary navigation">
        <a class="app-brand" href="/blog" aria-label="Tommy's Club home">
            <span class="app-brand-script">Tommy's</span>
            <span class="app-brand-block">CLUB</span>
        </a>
        <div class="issue-stamp" aria-hidden="true">EST. 2026 / ISSUE 01</div>

        <nav class="rail-nav">
            <div class="rail-section">
                <span class="rail-label">Read</span>
                {{#navLink "/blog"}}<i class="bi bi-house" aria-hidden="true"></i><span>Home</span>{{/navLink}}
                <a class="nav-link" href="/about"><i class="bi bi-info-square" aria-hidden="true"></i><span>About</span></a>
                {{#if session.user}}
                {{#navLink "/categories"}}<i class="bi bi-grid" aria-hidden="true"></i><span>Channels</span>{{/navLink}}
                {{/if}}
            </div>

            {{#if session.user}}
            <div class="rail-section">
                <span class="rail-label">Participate</span>
                {{#navLink "/chat"}}<i class="bi bi-chat-square-text" aria-hidden="true"></i><span>The Room</span><span class="unread-mark" data-unread-mark hidden>New</span>{{/navLink}}
                {{#navLink "/posts/add"}}<i class="bi bi-pencil-square" aria-hidden="true"></i><span>Write</span>{{/navLink}}
                {{#navLink "/posts"}}<i class="bi bi-collection" aria-hidden="true"></i><span>Dashboard</span>{{/navLink}}
            </div>
            <div class="rail-section">
                <span class="rail-label">Account</span>
                {{#navLink "/settings"}}<i class="bi bi-sliders2" aria-hidden="true"></i><span>Settings</span>{{/navLink}}
                {{#if session.user.isAdmin}}
                {{#navLink "/admin/approvals"}}<i class="bi bi-person-check" aria-hidden="true"></i><span>Approvals</span>{{/navLink}}
                {{/if}}
            </div>
            {{else}}
            <div class="rail-section rail-section--guest">
                <span class="rail-label">Membership</span>
                <a class="nav-link" href="/login"><i class="bi bi-door-open" aria-hidden="true"></i><span>Log in</span></a>
                <a class="nav-link nav-link--accent" href="/register"><i class="bi bi-person-plus" aria-hidden="true"></i><span>Create account</span></a>
            </div>
            {{/if}}
        </nav>

        {{#if session.user}}
        <div class="profile-menu rail-profile" data-profile-menu>
            <button class="profile-menu-trigger" type="button" data-profile-trigger
                aria-controls="railProfileMenu" aria-expanded="false">
                <span class="profile-avatar-small">
                    {{#if session.user.avatar_url}}
                    <img src="{{session.user.avatar_url}}" alt="">
                    {{else}}
                    <span>{{avatarInitial session.user.username}}</span>
                    {{/if}}
                </span>
                <span class="profile-trigger-copy">
                    <span class="profile-trigger-name">{{session.user.username}}</span>
                    <span class="profile-trigger-email">{{session.user.email}}</span>
                </span>
                <i class="bi bi-three-dots" aria-hidden="true"></i>
            </button>
            <div class="profile-dropdown" id="railProfileMenu" data-profile-content hidden>
                <span class="profile-menu-kicker">SIGNED IN</span>
                <strong class="profile-menu-name">{{session.user.username}}</strong>
                {{#if session.user.isAdmin}}<span class="admin-badge">ADMIN</span>{{/if}}
                <a class="dropdown-item" href="/profile"><i class="bi bi-person" aria-hidden="true"></i><span>View profile</span></a>
                <a class="dropdown-item" href="/settings"><i class="bi bi-sliders2" aria-hidden="true"></i><span>Settings</span></a>
                <div class="dropdown-divider"></div>
                <form method="POST" action="/logout" class="profile-menu-logout">
                    <input type="hidden" name="_csrf" value="{{csrfToken}}">
                    <button type="submit" class="dropdown-item"><i class="bi bi-box-arrow-right" aria-hidden="true"></i><span>Log out</span></button>
                </form>
            </div>
        </div>
        {{/if}}
    </aside>

    <header class="mobile-masthead">
        <a class="mobile-brand" href="/blog">Tommy's <span>CLUB</span></a>
        <span class="mobile-issue">ISSUE 01</span>
    </header>

    <main class="app-main" id="main-content" tabindex="-1">
        <div class="page-registration" aria-hidden="true"><span></span><span></span><span></span></div>
        {{{body}}}
    </main>

    <nav class="mobile-nav" aria-label="Mobile navigation">
        {{#if session.user}}
        {{#navLink "/blog"}}<i class="bi bi-house" aria-hidden="true"></i><span>Home</span>{{/navLink}}
        {{#navLink "/categories"}}<i class="bi bi-grid" aria-hidden="true"></i><span>Channels</span>{{/navLink}}
        <a class="mobile-write" href="/posts/add"><i class="bi bi-plus-lg" aria-hidden="true"></i><span>Write</span></a>
        {{#navLink "/chat"}}<i class="bi bi-chat-square-text" aria-hidden="true"></i><span>Chat</span><b class="mobile-unread" data-unread-mark hidden>New</b>{{/navLink}}
        <button type="button" data-mobile-profile-trigger aria-controls="mobileProfileSheet" aria-expanded="false"><i class="bi bi-person" aria-hidden="true"></i><span>Profile</span></button>
        {{else}}
        {{#navLink "/blog"}}<i class="bi bi-house" aria-hidden="true"></i><span>Home</span>{{/navLink}}
        {{#navLink "/about"}}<i class="bi bi-info-square" aria-hidden="true"></i><span>About</span>{{/navLink}}
        <a href="/login"><i class="bi bi-door-open" aria-hidden="true"></i><span>Log in</span></a>
        <a href="/register"><i class="bi bi-person-plus" aria-hidden="true"></i><span>Join</span></a>
        {{/if}}
    </nav>

    {{#if session.user}}
    <div class="mobile-profile-scrim" data-mobile-profile-scrim hidden></div>
    <section class="mobile-profile-sheet" id="mobileProfileSheet" aria-label="Profile menu" aria-hidden="true" hidden>
        <div class="sheet-handle" aria-hidden="true"></div>
        <div class="sheet-profile">
            <span class="profile-avatar-small">
                {{#if session.user.avatar_url}}<img src="{{session.user.avatar_url}}" alt="">{{else}}<span>{{avatarInitial session.user.username}}</span>{{/if}}
            </span>
            <div><strong>{{session.user.username}}</strong><span>{{session.user.email}}</span></div>
        </div>
        <a href="/profile"><i class="bi bi-person" aria-hidden="true"></i>Profile</a>
        <a href="/settings"><i class="bi bi-sliders2" aria-hidden="true"></i>Settings</a>
        <a href="/posts"><i class="bi bi-collection" aria-hidden="true"></i>Dashboard</a>
        <form method="POST" action="/logout">
            <input type="hidden" name="_csrf" value="{{csrfToken}}">
            <button type="submit"><i class="bi bi-box-arrow-right" aria-hidden="true"></i>Log out</button>
        </form>
    </section>
    {{/if}}
</div>

<script>
(function () {
    var tokenMeta = document.querySelector('meta[name="csrf-token"]');
    window.CSRF_TOKEN = tokenMeta ? tokenMeta.content : '';

    document.querySelectorAll('[data-profile-menu]').forEach(function (menu) {
        var trigger = menu.querySelector('[data-profile-trigger]');
        var content = menu.querySelector('[data-profile-content]');
        function setOpen(open, restoreFocus) {
            menu.classList.toggle('is-open', open);
            trigger.setAttribute('aria-expanded', String(open));
            content.hidden = !open;
            if (!open && restoreFocus) trigger.focus();
        }
        trigger.addEventListener('click', function (event) {
            event.stopPropagation();
            setOpen(!menu.classList.contains('is-open'), false);
        });
        document.addEventListener('click', function (event) {
            if (!menu.contains(event.target) && menu.classList.contains('is-open')) setOpen(false, true);
        });
        document.addEventListener('keydown', function (event) {
            if (event.key === 'Escape' && menu.classList.contains('is-open')) setOpen(false, true);
        });
    });

    var mobileTrigger = document.querySelector('[data-mobile-profile-trigger]');
    var mobileSheet = document.getElementById('mobileProfileSheet');
    var mobileScrim = document.querySelector('[data-mobile-profile-scrim]');
    function setMobileProfile(open, restoreFocus) {
        if (!mobileTrigger || !mobileSheet || !mobileScrim) return;
        mobileTrigger.setAttribute('aria-expanded', String(open));
        mobileSheet.setAttribute('aria-hidden', String(!open));
        mobileSheet.hidden = !open;
        mobileScrim.hidden = !open;
        document.body.classList.toggle('profile-sheet-open', open);
        if (open) {
            var firstAction = mobileSheet.querySelector('a, button');
            if (firstAction) window.setTimeout(function () { firstAction.focus(); }, 0);
        }
        if (!open && restoreFocus) mobileTrigger.focus();
    }
    if (mobileTrigger) mobileTrigger.addEventListener('click', function () {
        setMobileProfile(mobileTrigger.getAttribute('aria-expanded') !== 'true', false);
    });
    if (mobileScrim) mobileScrim.addEventListener('click', function () { setMobileProfile(false, true); });
    document.addEventListener('keydown', function (event) {
        if (event.key === 'Escape' && mobileTrigger && mobileTrigger.getAttribute('aria-expanded') === 'true') setMobileProfile(false, true);
    });

    {{#if session.user}}
    var unreadMarks = document.querySelectorAll('[data-unread-mark]');
    if (unreadMarks.length) {
        var lastSeen = parseInt(localStorage.getItem('tommys_club_last_msg') || '0', 10);
        fetch('/chat/unread-count').then(function (response) { return response.json(); }).then(function (data) {
            if (data.latestId && data.latestId > lastSeen) unreadMarks.forEach(function (mark) { mark.hidden = false; });
        }).catch(function () {});
    }
    {{/if}}
})();
</script>
</body>
</html>
