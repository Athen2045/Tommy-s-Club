    <div class="feature-item">&#x1F441;&nbsp; Anonymous Identities</div>
    <div class="feature-item">&#x1F512;&nbsp; Private by Default</div>
    <div class="feature-item">&#x2728;&nbsp; Curated Members</div>
</div>

