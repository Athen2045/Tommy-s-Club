<div class="admin-page">
    <div class="container py-5">
        <div class="d-flex align-items-center justify-content-between mb-4">
            <div>
                <h1 class="admin-title">Categories</h1>
                <p class="text-muted mb-0">Organise your posts by topic</p>
            </div>
            {{#if session.user.isAdmin}}
            <a href="/categories/add" class="btn btn-primary rounded-pill px-4">
                <i class="bi bi-plus-lg me-1"></i>New category
            </a>
            {{/if}}
        </div>

        {{#if message}}
        <div class="empty-state text-center py-5">
            <i class="bi bi-tags display-1 text-muted"></i>
            <h3 class="mt-3 text-muted">No categories yet</h3>
            <a href="/categories/add" class="btn btn-primary rounded-pill mt-2">Create one</a>
        </div>
        {{else}}
        <div class="row g-3">
            {{#each categories}}
            <div class="col-sm-6 col-md-4 col-lg-3">
                <div class="category-admin-card">
                    <div class="category-admin-icon">
                        <i class="bi bi-tag"></i>
                    </div>
                    <div class="flex-grow-1">
                        <div class="fw-semibold">{{name}}</div>
                        <div class="text-muted small">/{{slug}}</div>
                    </div>
                    <div class="d-flex gap-1">
                        <a href="/posts?category={{id}}" class="btn btn-ghost-xs" title="View posts">
                            <i class="bi bi-list-ul"></i>
                        </a>
                        {{#if ../session.user.isAdmin}}
                        <a href="/categories/delete/{{id}}"
                            class="btn btn-ghost-xs text-danger"
                            onclick="return confirm('Delete category «{{name}}»?')" title="Delete">
                            <i class="bi bi-trash"></i>
                        </a>
                        {{/if}}
                    </div>
                </div>
            </div>
            {{/each}}
        </div>
        {{/if}}
    </div>
</div>
