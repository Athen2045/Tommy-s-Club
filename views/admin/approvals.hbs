<div class="admin-header">
    <div>
        <h1 class="admin-title">Membership Queue</h1>
        <p class="admin-sub">Review pending applications</p>
    </div>
    <div class="wf-row" style="gap:8px">
        <span class="wf-chip wf-chip--pink">ADMIN</span>
        <a href="/posts" class="btn-action">&#x2190; Dashboard</a>
    </div>
</div>

{{#if errorMessage}}
<div class="gate-error mb-3" style="max-width:600px">{{errorMessage}}</div>
{{/if}}

{{#if pending.length}}
<div style="overflow-x:auto">
    <table class="crt-table">
        <thead>
            <tr>
                <th>Alias</th>
                <th>Requested</th>
                <th style="text-align:right">Action</th>
            </tr>
        </thead>
        <tbody>
            {{#each pending}}
            <tr>
                <td>
                    <div style="display:flex;align-items:center;gap:10px">
                        {{#if avatar_url}}
                        <img src="{{avatar_url}}" alt="" loading="lazy"
                            style="width:26px;height:26px;border-radius:50%;border:1px solid var(--neon-pink);object-fit:cover">
                        {{else}}
                        <div style="width:26px;height:26px;border-radius:50%;border:1px solid var(--neon-pink);
                                    background:rgba(255,43,214,0.08);display:flex;align-items:center;
                                    justify-content:center;font-family:var(--f-pixel);font-size:14px;color:var(--neon-pink)">
                            {{avatarInitial username}}
                        </div>
                        {{/if}}
                        <span class="cell-title">{{username}}</span>
                    </div>
                </td>
                <td class="cell-mono">{{timeAgo created_at}}</td>
                <td style="text-align:right;white-space:nowrap">
                    <form method="POST" action="/admin/approvals/{{id}}/approve" style="display:inline">
                        <input type="hidden" name="_csrf" value="{{@root.csrfToken}}">
                        <button type="submit" class="btn-approve">Approve</button>
                    </form>
                    <form method="POST" action="/admin/approvals/{{id}}/reject" style="display:inline;margin-left:6px"
                        data-confirm="Reject this member?">
                        <input type="hidden" name="_csrf" value="{{@root.csrfToken}}">
                        <button type="submit" class="btn-reject">Reject</button>
                    </form>
                </td>
            </tr>
            {{/each}}
        </tbody>
    </table>
</div>
{{else}}
<div class="empty-state">
    <i class="bi bi-person-check"></i>
    <h3>Queue is clear</h3>
    <p>No pending applications. You are all caught up.</p>
</div>
{{/if}}
