<div class="wf-row mb-3" style="gap:12px">
    <a href="/posts" class="wf-btn ghost sm">&#x2190;</a>
    <h1 class="wf-h2">New Post</h1>
</div>

<form method="POST" action="/posts/add" enctype="multipart/form-data" id="postForm"
    style="max-width:760px;display:flex;flex-direction:column;gap:18px">
    <input type="hidden" name="_csrf" value="{{csrfToken}}">
    <input type="hidden" name="feature_image_url" id="featureImageUrl">
    <input type="hidden" name="feature_image_file_id" id="featureImageFileId">

    {{#if errorMessage}}
    <div class="gate-error" role="alert" tabindex="-1">{{errorMessage}}</div>
    {{/if}}

    <!-- Title -->
    <input type="text" class="post-title-input" id="title" name="title"
        value="{{formData.title}}" placeholder="Give your story a title" maxlength="160" required>

    <!-- Quill editor -->
    <div>
        <div class="wf-label mb-2">Content</div>
        <div id="quill-editor"></div>
        <textarea name="body" id="bodyField" style="display:none">{{formData.body}}</textarea>
    </div>

    <!-- Channel + cover image -->
    <div class="wf-row" style="gap:16px;align-items:flex-start">
        <div class="gate-field" style="flex:1">
            <label class="gate-label">Channel</label>
            {{#if categories}}
            <select class="gate-input" name="category" id="category">
                <option value="">No channel</option>
                {{#each categories}}
                <option value="{{id}}" {{#equal id ../formData.category}}selected{{/equal}}>{{name}}</option>
                {{/each}}
            </select>
            {{else}}
            <div class="wf-mono" style="padding:8px 0">No channels yet.</div>
            {{/if}}
        </div>
        <div class="gate-field" style="flex:1.5">
            <label class="gate-label" for="featureImage">Cover image (optional)</label>
            <input class="gate-input file-input" type="file" id="featureImage" name="featureImage"
                accept="image/jpeg,image/png,image/gif,image/webp,image/avif"
                data-media-kind="post-cover" data-media-url-field="#featureImageUrl"
                data-media-id-field="#featureImageFileId" data-media-feedback="#featureImageFeedback">
            <span class="form-helper">JPEG, PNG, GIF, WebP, or AVIF.</span>
            <span class="form-helper form-upload-feedback" id="featureImageFeedback" aria-live="polite"></span>
        </div>
    </div>

    <!-- Actions -->
    <div class="post-submit-actions">
        <button type="submit" class="post-action-btn post-action-btn--draft" name="intent" value="draft">
            <i class="bi bi-floppy" aria-hidden="true"></i> Save Draft
        </button>
        <button type="submit" class="post-action-btn post-action-btn--publish" name="intent" value="publish">
            <i class="bi bi-send" aria-hidden="true"></i> Publish
        </button>
        <a href="/posts" class="post-action-cancel">Cancel</a>
    </div>
    <p class="form-helper post-publish-helper">Drafts remain private until you publish them.</p>

</form>

<link href="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.snow.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.js"></script>
<script>
(function () {
    var quill = new Quill('#quill-editor', {
        theme: 'snow',
        placeholder: 'Write anything. A haiku. A rant. A memory. A question with no answer.',
        modules: {
            toolbar: {
                container: [
                    [{ header: [1, 2, false] }],
                    ['bold', 'italic', 'blockquote', 'code-block'],
                    [{ list: 'bullet' }],
                    ['link', 'image'],
                    ['clean']
                ],
                handlers: {
                    image: function () {
                        var input = document.createElement('input');
                        input.setAttribute('type', 'file');
                        input.setAttribute('accept', 'image/*');
                        input.click();
                        input.onchange = function () {
                            var file = input.files[0];
                            if (!file) return;
                            window.TommyMedia.upload(file, 'post-inline')
                                .then(function (media) {
                                    return fetch('/posts/upload-image', {
                                        method: 'POST',
                                        headers: { 'X-CSRF-Token': window.CSRF_TOKEN, 'Accept': 'application/json', 'Content-Type': 'application/json' },
                                        body: JSON.stringify({ image_url: media.url, image_file_id: media.fileId })
                                    });
                                })
                                .then(function (r) { return r.json().then(function (json) { if (!r.ok) throw new Error(json.error || 'Upload failed'); return json; }); })
                                .then(function (json) {
                                    if (json.url) {
                                        var range = quill.getSelection(true);
                                        quill.insertEmbed(range.index, 'image', json.url);
                                    }
                                })
                                .catch(function (error) { window.alert(error.message); });
                        };
                    }
                }
            }
        }
    });

    var initialBody = document.getElementById('bodyField').value;
    if (initialBody) quill.clipboard.dangerouslyPasteHTML(initialBody);

    document.getElementById('postForm').addEventListener('submit', function () {
        document.getElementById('bodyField').value = quill.root.innerHTML;
    });
})();
</script>
