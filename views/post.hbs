<div class="post-view">

    <!-- Back link -->
    <a href="/blog" class="post-view-back">&#x2190; Back to the stories</a>

    <!-- Category -->
    {{#if post.categories}}
    <div class="post-view-cat">{{post.categories.name}}</div>
    {{/if}}

    <!-- Title -->
    <h1 class="post-view-title">{{post.title}}</h1>

    <!-- Meta -->
    <div class="post-view-meta">
        <a href="/member/{{post.profiles.username}}">{{post.profiles.username}}</a>
        <span class="sep">&middot;</span>
        <span>{{formatDate post.created_at}}</span>
        <span class="sep">&middot;</span>
        <span>{{readTime post.body}}</span>
        <span class="sep">&middot;</span>
        <span>{{commentCount}} comment{{#gt commentCount 1}}s{{/gt}}</span>
    </div>

    <!-- Feature image -->
    {{#if post.feature_image}}
    <img src="{{post.feature_image}}" alt="{{post.title}}" class="post-view-img" loading="eager" fetchpriority="high">
    {{/if}}

    <!-- Body -->
    <div class="post-view-body">
        {{{safeHTML post.body}}}
    </div>

    <!-- Reactions -->
    <div class="reaction-bar" id="reactionBar" data-post-id="{{post.id}}"></div>

</div>

<!-- Comments -->
<section class="comments-section" id="comments" style="max-width:700px">

    <h3 class="comments-heading">
        <i class="bi bi-chat-square-text" aria-hidden="true"></i> {{commentCount}} Comment{{#gt commentCount 1}}s{{/gt}}
    </h3>

    <!-- New comment form -->
    {{#if session.user}}
    <div class="comment-form-card">
        <div class="meta-avatar">
            {{#if session.user.avatar_url}}
            <img src="{{session.user.avatar_url}}" alt="you">
            {{else}}
            <span class="meta-avatar-initials">{{avatarInitial session.user.username}}</span>
            {{/if}}
        </div>
        <form method="POST" action="/blog/{{post.id}}/comments" style="flex:1">
            <input type="hidden" name="_csrf" value="{{csrfToken}}">
            <textarea name="body" class="comment-textarea" rows="3"
                placeholder="Share your thoughts…" required></textarea>
            <div style="display:flex;justify-content:flex-end;margin-top:6px">
                <button type="submit" class="comment-submit-btn">&#x25B8; Post comment</button>
            </div>
        </form>
    </div>
    {{else}}
    <div class="comment-cta">
        <a href="/login">Sign in</a> or <a href="/register">create an account</a> to join the conversation.
    </div>
    {{/if}}

    <!-- Comment thread -->
    {{#if commentTree}}
    <div class="comment-list">
        {{#each commentTree}}
        <div class="comment-item" id="comment-{{id}}">
            <div class="meta-avatar">
                {{#if profiles.avatar_url}}
                <img src="{{profiles.avatar_url}}" alt="" loading="lazy">
                {{else}}
                <span class="meta-avatar-initials">{{avatarInitial profiles.username}}</span>
                {{/if}}
            </div>
            <div style="flex:1">
                <div class="comment-meta">
                    <a href="/member/{{profiles.username}}" class="comment-author">{{profiles.username}}</a>
                    <span class="comment-date">{{timeAgo created_at}}</span>
                </div>
                <p class="comment-body">{{body}}</p>
                <div class="comment-actions">
                    {{#if ../session.user}}
                    <button class="reply-toggle" data-id="{{id}}">&#x21B5; Reply</button>
                    {{/if}}
                    {{#equal ../session.user.id author_id}}
                    <form method="POST" action="/comments/delete/{{id}}"
                        style="display:inline"
                        onsubmit="return confirm('Delete this comment?')">
                        <input type="hidden" name="_csrf" value="{{@root.csrfToken}}">
                        <input type="hidden" name="postId" value="{{../post.id}}">
                        <button type="submit" class="comment-delete-link"
                            style="background:none;border:none;padding:0;cursor:pointer">Delete</button>
                    </form>
                    {{/equal}}
                </div>

                <!-- Reply form (hidden by default) -->
                {{#if ../session.user}}
                <div class="reply-form" id="reply-form-{{id}}" style="display:none">
                    <form method="POST" action="/blog/{{../post.id}}/comments">
                        <input type="hidden" name="_csrf" value="{{@root.csrfToken}}">
                        <input type="hidden" name="parent_id" value="{{id}}">
                        <textarea name="body" class="comment-textarea" rows="2"
                            placeholder="Write a reply…" required></textarea>
                        <div style="display:flex;gap:8px;justify-content:flex-end;margin-top:6px">
                            <button type="button" class="cancel-reply" data-id="{{id}}">Cancel</button>
                            <button type="submit" class="comment-submit-btn">Reply</button>
                        </div>
                    </form>
                </div>
                {{/if}}

                <!-- Nested replies -->
                {{#if replies}}
                <div style="margin-top:10px;display:flex;flex-direction:column;gap:10px">
                    {{#each replies}}
                    <div class="comment-item reply-item" id="comment-{{id}}">
                        <div class="meta-avatar-xs">
                            {{#if profiles.avatar_url}}
                            <img src="{{profiles.avatar_url}}" alt="" loading="lazy">
                            {{else}}
                            <span class="meta-avatar-initials-xs">{{avatarInitial profiles.username}}</span>
                            {{/if}}
                        </div>
                        <div style="flex:1">
                            <div class="comment-meta">
                                <a href="/member/{{profiles.username}}" class="comment-author">{{profiles.username}}</a>
                                <span class="comment-date">{{timeAgo created_at}}</span>
                            </div>
                            <p class="comment-body">{{body}}</p>
                            {{#equal ../../session.user.id author_id}}
                            <form method="POST" action="/comments/delete/{{id}}"
                                style="display:inline"
                                onsubmit="return confirm('Delete this reply?')">
                                <input type="hidden" name="_csrf" value="{{@root.csrfToken}}">
                                <input type="hidden" name="postId" value="{{../../post.id}}">
                                <button type="submit" class="comment-delete-link"
                                    style="background:none;border:none;padding:0;cursor:pointer">Delete</button>
                            </form>
                            {{/equal}}
                        </div>
                    </div>
                    {{/each}}
                </div>
                {{/if}}
            </div>
        </div>
        {{/each}}
    </div>
    {{else}}
    <div class="empty-state" style="padding:20px 0">
        <i class="bi bi-chat"></i>
        <p>No comments yet. Be the first!</p>
    </div>
    {{/if}}

</section>

<script>
document.querySelectorAll('.reply-toggle').forEach(function (btn) {
    btn.addEventListener('click', function () {
        var form = document.getElementById('reply-form-' + btn.dataset.id);
        if (form) {
            form.style.display = form.style.display === 'none' ? 'block' : 'none';
            if (form.style.display === 'block') form.querySelector('textarea').focus();
        }
    });
});
document.querySelectorAll('.cancel-reply').forEach(function (btn) {
    btn.addEventListener('click', function () {
        var form = document.getElementById('reply-form-' + btn.dataset.id);
        if (form) form.style.display = 'none';
    });
});
</script>

<script>
(function () {
    var KEYS  = ['fire','heart','eye','sparkle','black_heart'];
    var ICON = { fire:'bi-fire', heart:'bi-heart', eye:'bi-eye', sparkle:'bi-stars', black_heart:'bi-suit-heart-fill' };
    var LABEL = { fire:'Fire', heart:'Heart', eye:'Interesting', sparkle:'Sparkle', black_heart:'Black heart' };
    var bar   = document.getElementById('reactionBar');
    if (!bar) return;
    var postId      = bar.dataset.postId;
    var counts      = {{{reactionCounts}}};
    var userReacted = {{{userReactions}}};

    function renderBar() {
        bar.textContent = '';
        KEYS.forEach(function (key) {
            var btn = document.createElement('button');
            btn.className = 'reaction-btn' + (userReacted.indexOf(key) !== -1 ? ' reaction-btn--active' : '');
            btn.setAttribute('data-key', key);
            btn.setAttribute('type', 'button');
            btn.setAttribute('aria-label', LABEL[key] + ' reaction, ' + (counts[key] || 0));
            btn.setAttribute('title', LABEL[key]);
            btn.addEventListener('click', function () { react(key); });
            var emojiSpan = document.createElement('i');
            emojiSpan.className = 'bi ' + ICON[key];
            emojiSpan.setAttribute('aria-hidden', 'true');
            var countSpan = document.createElement('span');
            countSpan.className = 'reaction-count';
            countSpan.textContent = counts[key] || 0;
            btn.appendChild(emojiSpan);
            btn.appendChild(document.createTextNode(' '));
            btn.appendChild(countSpan);
            bar.appendChild(btn);
        });
    }

    function react(key) {
        fetch('/blog/' + postId + '/react', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': window.CSRF_TOKEN },
            body: JSON.stringify({ emoji: key })
        })
        .then(function (r) { return r.json(); })
        .then(function (data) {
            if (data.counts) {
                counts      = data.counts;
                userReacted = data.userReactions;
                renderBar();
            }
        });
    }

    renderBar();
})();
</script>
