<div class="admin-page">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-sm-10 col-md-7 col-lg-5">
                <div class="d-flex align-items-center gap-3 mb-4">
                    <a href="/categories" class="btn btn-ghost-sm">
                        <i class="bi bi-arrow-left"></i>
                    </a>
                    <h1 class="admin-title mb-0">New Category</h1>
                </div>

                <div class="auth-card">
                    <form method="POST" action="/categories/add">
                        <div class="mb-4">
                            <label class="form-label fw-medium" for="category">Category name</label>
                            <input class="form-control form-control-lg" id="category" name="category"
                                type="text" placeholder="e.g. Technology" autofocus required>
                            <div class="text-muted small mt-1">A URL-friendly slug will be generated automatically.</div>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary rounded-pill px-4">
                                Create category
                            </button>
                            <a href="/categories" class="btn btn-outline-secondary rounded-pill px-4">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
