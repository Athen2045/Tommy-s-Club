<div class="wf-row mb-3" style="gap:12px">
    <a href="/posts" class="wf-btn ghost sm">&#x2190;</a>
    <h1 class="wf-h2">New Post</h1>
</div>

<form method="POST" action="/posts/add" enctype="multipart/form-data" id="postForm"
    style="max-width:760px;display:flex;flex-direction:column;gap:18px">
    <input type="hidden" name="_csrf" value="{{csrfToken}}">

    <!-- Title -->
    <input type="text" class="post-title-input" id="title" name="title"
        placeholder="Title (optional)">

    <!-- Quill editor -->
    <div>
        <div class="wf-label mb-2">Content</div>
        <div id="quill-editor"></div>
        <textarea name="body" id="bodyField" style="display:none"></textarea>
    </div>

    <!-- Channel + cover image -->
    <div class="wf-row" style="gap:16px;align-items:flex-start">
        <div class="gate-field" style="flex:1">
            <label class="gate-label">Channel</label>
            {{#if categories}}
            <select class="gate-input" name="category" id="category">
                <option value="">No channel</option>
                {{#each categories}}
                <option value="{{id}}">{{name}}</option>
                {{/each}}
            </select>
            {{else}}
            <div class="wf-mono" style="padding:8px 0">No channels yet.</div>
            {{/if}}
        </div>
        <div class="gate-field" style="flex:1.5">
            <label class="gate-label">Cover Image (optional)</label>
            <input class="gate-input" type="file" id="featureImage" name="featureImage"
                accept="image/*" style="padding:6px 12px;cursor:pointer">
        </div>
    </div>

    <!-- Publish toggle -->
    <div style="display:flex;align-items:center;gap:10px">
        <input type="checkbox" id="published" name="published"
            style="accent-color:var(--neon-pink);width:14px;height:14px">
        <label class="gate-label" for="published" style="cursor:pointer;letter-spacing:0.12em">
            Publish immediately
        </label>
        <span class="wf-mono" style="font-size:10px;color:var(--ink-faint)">— drafts are private</span>
    </div>

    <!-- Actions -->
    <div class="wf-row" style="gap:10px">
        <button type="submit" class="gate-btn" style="width:auto;padding:10px 28px;display:inline-block">
            &#x25B8; Publish
        </button>
        <a href="/posts" class="gate-btn ghost" style="width:auto;padding:10px 24px;display:inline-block">Cancel</a>
    </div>

</form>

<link href="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.snow.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.js"></script>
<script>
(function () {
    var quill = new Quill('#quill-editor', {
        theme: 'snow',
        placeholder: 'Write anything. A haiku. A rant. A memory. A question with no answer.',
        modules: {
            toolbar: {
                container: [
                    [{ header: [1, 2, false] }],
                    ['bold', 'italic', 'blockquote', 'code-block'],
                    [{ list: 'bullet' }],
                    ['link', 'image'],
                    ['clean']
                ],
                handlers: {
                    image: function () {
                        var input = document.createElement('input');
                        input.setAttribute('type', 'file');
                        input.setAttribute('accept', 'image/*');
                        input.click();
                        input.onchange = function () {
                            var file = input.files[0];
                            if (!file) return;
                            var fd = new FormData();
                            fd.append('image', file);
                            fetch('/posts/upload-image', { method: 'POST', headers: { 'X-CSRF-Token': window.CSRF_TOKEN }, body: fd })
                                .then(function (r) { return r.json(); })
                                .then(function (json) {
                                    if (json.url) {
                                        var range = quill.getSelection(true);
                                        quill.insertEmbed(range.index, 'image', json.url);
                                    }
                                });
                        };
                    }
                }
            }
        }
    });

    document.getElementById('postForm').addEventListener('submit', function () {
        document.getElementById('bodyField').value = quill.root.innerHTML;
    });
})();
</script>
