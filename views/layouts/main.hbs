<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{#if title}}{{title}} — {{/if}}Tommy's Club</title>
    <meta name="csrf-token" content="{{csrfToken}}">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=VT323&family=IBM+Plex+Mono:wght@400;500;600&family=Caveat:wght@400;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/crt.css">
</head>
<body>

<div class="crt">
    <div class="crt-screen" id="crtScreen">
        <div class="crt-content">
            <div class="crt-sweep"></div>

            <!-- ── Topbar ─────────────────────────────────────── -->
            <header class="crt-topbar">
                <button class="crt-hamburger" id="sidebarToggle" aria-label="Menu">&#x2630;</button>

                <a class="crt-brand" href="/blog">Tommy's <span>CLUB</span></a>

                <nav class="crt-topbar-nav">
                    {{#navLink "/blog"}}Home{{/navLink}}
                    {{#navLink "/about"}}About{{/navLink}}
                </nav>

                <div class="crt-topbar-end">
                    <a href="/posts/add" class="wf-btn sm cyan" style="display:flex;align-items:center;gap:5px;font-size:13px;padding:4px 12px;letter-spacing:1px;">
                        <i class="bi bi-pencil-square"></i> Write
                    </a>

                    <!-- Bootstrap dropdown for user menu -->
                    <div class="dropdown">
                        <button class="crt-avatar-btn" data-bs-toggle="dropdown" data-bs-display="static" aria-expanded="false">
                            {{#if session.user.avatar_url}}
                            <img src="{{session.user.avatar_url}}" alt="avatar">
                            {{else}}
                            <span class="crt-avatar-initials">{{avatarInitial session.user.username}}</span>
                            {{/if}}
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end mt-2">
                            <li>
                                <span class="dropdown-item-text">
                                    {{session.user.username}}
                                    {{#if session.user.isAdmin}}<span class="admin-badge">ADMIN</span>{{/if}}
                                </span>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="/posts"><i class="bi bi-grid-3x3-gap"></i>Dashboard</a></li>
                            {{#if session.user.isAdmin}}
                            <li><a class="dropdown-item" href="/admin/approvals"><i class="bi bi-person-check"></i>Approvals</a></li>
                            {{/if}}
                            <li><a class="dropdown-item" href="/chat"><i class="bi bi-chat"></i>The Room</a></li>
                            <li><a class="dropdown-item" href="/categories"><i class="bi bi-tags"></i>Channels</a></li>
                            <li><a class="dropdown-item" href="/profile"><i class="bi bi-person"></i>Profile</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><form method="POST" action="/logout" class="dropdown-item p-0">
                                <input type="hidden" name="_csrf" value="{{csrfToken}}">
                                <button type="submit" class="dropdown-item"><i class="bi bi-box-arrow-right"></i>Sign out</button>
                            </form></li>
                        </ul>
                    </div>
                </div>
            </header>

            <!-- ── Body (sidebar + content) ────────────────────── -->
            <div class="crt-body-wrap">

                <!-- Sidebar overlay -->
                <div class="crt-overlay" id="crtOverlay"></div>

                <!-- Sidebar -->
                <aside class="crt-sidebar" id="crtSidebar">
                    <div class="crt-sidebar-head">
                        <a class="crt-sidebar-brand" href="/blog">Tommy's</a>
                        <button class="crt-sidebar-close" id="sidebarClose" aria-label="Close">&#x00D7;</button>
                    </div>

                    <nav style="flex:1;overflow-y:auto;padding:8px 0;">
                        <div class="crt-sidebar-section">
                            <div class="crt-sidebar-section-label">Browse</div>
                            {{#navLink "/blog"}}<i class="bi bi-journal-text"></i> All Posts{{/navLink}}
                            {{#navLink "/categories"}}<i class="bi bi-tags"></i> Channels{{/navLink}}
                        </div>
                        <div class="crt-sidebar-section">
                            <div class="crt-sidebar-section-label">Community</div>
                            {{#navLink "/chat"}}<i class="bi bi-chat-fill"></i> The Room
                                <span class="crt-unread-dot" id="sidebarUnreadDot"></span>
                            {{/navLink}}
                        </div>
                        <div class="crt-sidebar-section">
                            <div class="crt-sidebar-section-label">You</div>
                            {{#navLink "/posts/add"}}<i class="bi bi-pencil-square"></i> Write{{/navLink}}
                            {{#navLink "/profile"}}<i class="bi bi-person"></i> Profile{{/navLink}}
                            {{#navLink "/posts"}}<i class="bi bi-grid-3x3-gap"></i> Dashboard{{/navLink}}
                            {{#if session.user.isAdmin}}
                            {{#navLink "/admin/approvals"}}<i class="bi bi-person-check"></i> Approvals{{/navLink}}
                            {{/if}}
                        </div>
                    </nav>
                </aside>

                <!-- Main content -->
                <main class="crt-main" id="crtMain">
                    {{{body}}}
                </main>

            </div>
        </div>
    </div>
    <div class="crt-led"></div>
</div>

<!-- Bootstrap JS for dropdown only -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
(function () { window.CSRF_TOKEN = document.querySelector('meta[name="csrf-token"]').content; })();
(function () {
    var toggle   = document.getElementById('sidebarToggle');
    var sidebar  = document.getElementById('crtSidebar');
    var overlay  = document.getElementById('crtOverlay');
    var closeBtn = document.getElementById('sidebarClose');

    function openSidebar()  { sidebar.classList.add('open');    overlay.classList.add('open'); }
    function closeSidebar() { sidebar.classList.remove('open'); overlay.classList.remove('open'); }

    if (toggle)   toggle.addEventListener('click', openSidebar);
    if (overlay)  overlay.addEventListener('click', closeSidebar);
    if (closeBtn) closeBtn.addEventListener('click', closeSidebar);

    // Unread dot on sidebar chat link
    var dot = document.getElementById('sidebarUnreadDot');
    if (dot) {
        var lastSeen = parseInt(localStorage.getItem('tommys_club_last_msg') || '0', 10);
        fetch('/chat/unread-count')
            .then(function (r) { return r.json(); })
            .then(function (d) {
                if (d.latestId && d.latestId > lastSeen) dot.style.display = 'inline-block';
            })
            .catch(function () {});
    }
})();
</script>
</body>
</html>
