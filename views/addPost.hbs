<div class="wf-row mb-3" style="gap:12px">
    <a href="/posts" class="wf-btn ghost sm">&#x2190;</a>
    <h1 class="wf-h2">New Post</h1>
</div>

<form method="POST" action="/posts/add" id="postForm"
    style="max-width:760px;display:flex;flex-direction:column;gap:18px">
    <input type="hidden" name="_csrf" value="{{csrfToken}}">

    {{#if errorMessage}}
    <div class="gate-error" role="alert" tabindex="-1">{{errorMessage}}</div>
    {{/if}}

    <!-- Title -->
    <label class="gate-label" for="title">Story title</label>
    <input type="text" class="post-title-input" id="title" name="title"
        value="{{formData.title}}" placeholder="Give your story a title" maxlength="160" required>

    <!-- Quill editor -->
    <div>
        <div class="wf-label mb-2" id="contentLabel">Content</div>
        <div id="quill-editor" aria-labelledby="contentLabel"></div>
        <textarea name="body" id="bodyField" style="display:none">{{formData.body}}</textarea>
    </div>

    <div class="gate-field">
        <label class="gate-label" for="category">Channel</label>
        {{#if categories}}
        <select class="gate-input" name="category" id="category">
            <option value="">No channel</option>
            {{#each categories}}
            <option value="{{id}}" {{#equal id ../formData.category}}selected{{/equal}}>{{name}}</option>
            {{/each}}
        </select>
        {{else}}
        <div class="wf-mono" style="padding:8px 0">No channels yet.</div>
        {{/if}}
    </div>

    <section class="post-media-composer" data-post-media aria-labelledby="postMediaHeading">
        <div class="post-media-heading">
            <div>
                <span class="wf-eyebrow">Optional gallery</span>
                <h2 id="postMediaHeading">Add up to four images</h2>
            </div>
            <span class="post-media-count" data-post-media-count>0 / 4</span>
        </div>
        <p class="form-helper">The first image becomes the feed cover. JPEG, PNG, GIF, WebP, or AVIF; 8 MB per image.</p>
        <label class="file-picker-button" for="postImages">
            <i class="bi bi-images" aria-hidden="true"></i>
            <span>Choose images</span>
        </label>
        <input class="sr-only" type="file" id="postImages" accept="image/jpeg,image/png,image/gif,image/webp,image/avif" multiple data-post-media-input>
        <div class="post-media-list" data-post-media-list></div>
        <p class="form-upload-feedback" data-post-media-feedback aria-live="polite"></p>
    </section>

    <!-- Actions -->
    <div class="post-submit-actions">
        <button type="submit" class="post-action-btn post-action-btn--draft" name="intent" value="draft">
            <i class="bi bi-floppy" aria-hidden="true"></i> Save Draft
        </button>
        <button type="submit" class="post-action-btn post-action-btn--publish" name="intent" value="publish">
            <i class="bi bi-send" aria-hidden="true"></i> Publish
        </button>
        <a href="/posts" class="post-action-cancel">Cancel</a>
    </div>
    <p class="form-helper post-publish-helper">Drafts remain private until you publish them.</p>

</form>

<link href="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.snow.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.js"></script>
<script>
(function () {
    var quill = new Quill('#quill-editor', {
        theme: 'snow',
        placeholder: 'Write anything. A haiku. A rant. A memory. A question with no answer.',
        modules: {
            toolbar: {
                container: [
                    [{ header: [1, 2, false] }],
                    ['bold', 'italic', 'blockquote', 'code-block'],
                    [{ list: 'bullet' }],
                    ['link'],
                    ['clean']
                ]
            }
        }
    });

    var initialBody = document.getElementById('bodyField').value;
    if (initialBody) quill.clipboard.dangerouslyPasteHTML(initialBody);

    document.getElementById('postForm').addEventListener('submit', function () {
        document.getElementById('bodyField').value = quill.root.innerHTML;
    });
})();
</script>
<script src="/js/post-media.js" defer></script>
