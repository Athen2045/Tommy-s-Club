<div class="admin-header">
    <div>
        <h1 class="admin-title">Dashboard</h1>
        <p class="admin-sub">Manage your posts</p>
    </div>
    <a href="/posts/add" class="wf-btn cyan sm">&#x25B8; New Post</a>
</div>

<!-- Filter row -->
<div class="filter-row">
    <form method="GET" action="/posts" style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
        <select name="category" class="gate-input" style="width:auto;min-width:130px">
            <option value="">All channels</option>
            {{#each categories}}
            <option value="{{id}}">{{name}}</option>
            {{/each}}
        </select>
        <input type="date" name="minDate" class="gate-input" style="width:auto">
        <button type="submit" class="btn-action">Filter</button>
        <a href="/posts" class="btn-action ghost" style="border-color:var(--ink-ghost);color:var(--ink-faint)">Clear</a>
    </form>
</div>

{{#if message}}
<div class="empty-state">
    <i class="bi bi-journal-x"></i>
    <h3>No posts found</h3>
    <a href="/posts/add" class="wf-btn mt-3" style="display:inline-block">&#x25B8; Write your first post</a>
</div>
{{else}}
<div style="overflow-x:auto">
    <table class="crt-table">
        <thead>
            <tr>
                <th>Title</th>
                {{#if session.user.isAdmin}}<th>Author</th>{{/if}}
                <th>Channel</th>
                <th>Status</th>
                <th>Date</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            {{#each posts}}
            <tr>
                <td>
                    <a href="/blog/{{id}}" class="cell-title" style="text-decoration:none;color:var(--ink)">
                        {{#if title}}{{title}}{{else}}<em style="color:var(--ink-faint)">(untitled)</em>{{/if}}
                    </a>
                </td>
                {{#if ../session.user.isAdmin}}
                <td class="cell-mono">{{profiles.username}}</td>
                {{/if}}
                <td>
                    {{#if categories}}
                    <span class="wf-chip wf-chip--pink">{{categories.name}}</span>
                    {{else}}
                    <span style="color:var(--ink-ghost)">—</span>
                    {{/if}}
                </td>
                <td>
                    {{#if published}}
                    <span class="status-badge published">Live</span>
                    {{else}}
                    <span class="status-badge draft">Draft</span>
                    {{/if}}
                </td>
                <td class="cell-mono">{{formatDate created_at}}</td>
                <td style="text-align:right;white-space:nowrap">
                    <a href="/blog/{{id}}" class="btn-edit" title="View">View</a>
                    <form method="POST" action="/posts/delete/{{id}}"
                        style="display:inline;margin-left:6px"
                        data-confirm="Delete this post?">
                        <input type="hidden" name="_csrf" value="{{@root.csrfToken}}">
                        <button type="submit" class="btn-delete" title="Delete">Del</button>
                    </form>
                </td>
            </tr>
            {{/each}}
        </tbody>
    </table>
</div>
{{/if}}
