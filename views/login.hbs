<!-- Brick wall background -->
<div class="brick-wall" style="opacity:0.65"></div>

<button class="boot-skip" id="bootSkip" type="button">Skip intro</button>

<div class="login-stage">
<!-- Boot sequence wrapper: dots → POST text → Tommy's neon sign -->
<div class="boot-wrap">
    <!-- Stage 1: Loading dots -->
    <div class="boot-dots">
        <div class="boot-dot"></div>
        <div class="boot-dot"></div>
        <div class="boot-dot"></div>
    </div>

    <!-- Stage 2: POST self-test text -->
    <div class="boot-text">
        TOMMY'S CLUB&nbsp;&nbsp;·&nbsp;&nbsp;SYSTEM v1.9.85&nbsp;&nbsp;·&nbsp;&nbsp;POST OK&nbsp;&nbsp;·&nbsp;&nbsp;MEMORY 640K
    </div>

    <!-- Stage 3: Neon sign sputters in -->
    <div class="boot-sign-wrap">
        <div class="neon-sign-stack">
            <div class="neon-tommys">Tommy's</div>
            <div class="neon-club">CLUB</div>
        </div>
    </div>
</div>

<!-- Stage 4: Login form appears directly below the sign -->
<div class="boot-login">
    {{#if errorMessage}}
    <p class="gate-error">{{errorMessage}}</p>
    {{/if}}
    {{#if successMessage}}
    <p class="gate-success">{{successMessage}}</p>
    {{/if}}

        <form method="POST" action="/login" class="gate-form">
            <input type="hidden" name="_csrf" value="{{csrfToken}}">
        <div class="gate-field">
            <label class="gate-label" for="loginEmail">Email</label>
            <input type="email" name="email" id="loginEmail" class="gate-input" value="{{email}}"
                placeholder="anon@member.club" required autofocus autocomplete="email">
        </div>
        <div class="gate-field">
            <label class="gate-label" for="loginPassword">Password</label>
            <input type="password" name="password" id="loginPassword" class="gate-input"
                placeholder="••••••••" required autocomplete="current-password">
        </div>
        <button type="submit" class="gate-btn">&#x25B8; ENTER</button>
        <p class="gate-switch mt-2">No alias? <a href="/register">Request access</a></p>
    </form>
</div>
</div>

<script>
(function () {
    var skip = document.getElementById('bootSkip');
    if (!skip) return;
    skip.addEventListener('click', function () {
        document.body.classList.add('intro-skipped');
        var email = document.querySelector('.boot-login input[type="email"]');
        if (email) email.focus();
    });
})();
</script>
