<section class="chat-room" aria-labelledby="roomTitle">
    <header class="chat-room-header">
        <div>
            <span class="chat-room-kicker">COMMUNITY WIRE / LIVE</span>
            <h1 class="chat-room-title" id="roomTitle">The Room</h1>
        </div>
        <span class="chat-room-status">Connected</span>
    </header>

    <div class="chat-layout">
        <aside class="chat-members" aria-label="Club members">
            <div class="chat-members-heading">MEMBERS</div>
            <div id="membersList"></div>
        </aside>

        <div class="chat-panel">
            <div class="chat-messages" id="chatMessages" aria-live="polite">
                {{#each messages}}
                <article class="chat-msg" data-id="{{id}}" data-author="{{author_id}}">
                    <div class="chat-msg-avatar">
                        {{#if profiles.avatar_url}}
                        <img src="{{profiles.avatar_url}}" alt="" class="chat-avatar-img" loading="lazy">
                        {{else}}
                        <span class="chat-avatar-initials">{{avatarInitial profiles.username}}</span>
                        {{/if}}
                    </div>
                    <div class="chat-msg-content">
                        <div class="chat-msg-meta">
                            <a href="/member/{{profiles.username}}" class="chat-msg-author">{{profiles.username}}</a>
                            <time class="chat-msg-time" data-ts="{{created_at}}"></time>
                        </div>
                        {{#if body}}<div class="chat-msg-body" data-raw="{{body}}"></div>{{/if}}
                        {{#if image_url}}
                        <a class="chat-msg-image-link" href="{{mediaUrl image_url "post"}}" target="_blank" rel="noopener noreferrer" aria-label="Open image from {{profiles.username}}">
                            <img class="chat-msg-image" src="{{mediaUrl image_url "chat"}}" alt="Image shared by {{profiles.username}}" loading="lazy" width="320" height="320">
                        </a>
                        {{/if}}
                    </div>
                    <button class="chat-delete-btn" data-msgid="{{id}}" title="Delete message" aria-label="Delete message" type="button">
                        <i class="bi bi-trash" aria-hidden="true"></i>
                    </button>
                </article>
                {{/each}}
            </div>

            <div class="mention-dropdown" id="mentionDropdown" role="listbox"></div>

            <div class="chat-composer">
                <div class="chat-image-preview" id="chatImagePreview" hidden>
                    <img id="chatImagePreviewImg" alt="Selected image preview">
                    <div>
                        <strong id="chatImageName"></strong>
                        <span>Compressed for the room when sent</span>
                    </div>
                    <button id="chatImageRemove" type="button" aria-label="Remove selected image"><i class="bi bi-x-lg" aria-hidden="true"></i></button>
                </div>
                <div class="chat-composer-row">
                    <label class="chat-image-picker" for="chatImageInput" title="Add an image">
                        <i class="bi bi-image" aria-hidden="true"></i>
                        <span class="visually-hidden">Add an image</span>
                    </label>
                    <input class="visually-hidden" id="chatImageInput" type="file" accept="image/jpeg,image/png,image/gif,image/webp,image/avif">
                    <label class="visually-hidden" for="chatInput">Message the room</label>
                    <textarea id="chatInput" class="chat-input gate-input" placeholder="Message the room… Use @ to mention someone"
                        rows="1" maxlength="2000"></textarea>
                    <button class="chat-send-btn" id="chatSendBtn" type="button">Send</button>
                </div>
                <span class="chat-feedback" id="chatFeedback" aria-live="polite"></span>
            </div>
        </div>
    </div>
</section>

<script type="application/json" id="chatConfig">{{{chatConfigJson}}}</script>
<script src="/js/chat.js" defer></script>
