<div class="brick-wall" style="opacity:0.6"></div>

<div class="gate-wrap" style="z-index:5">
    <!-- Tommy's neon sign (small) -->
    <div class="neon-sign-stack sm">
        <div class="neon-tommys">Tommy's</div>
        <div class="neon-club">CLUB</div>
    </div>

    <div class="gate-eyebrow" style="margin-top:-6px">— Request Access —</div>

    {{#if errorMessage}}
    <p class="gate-error" style="width:100%;max-width:360px">{{errorMessage}}</p>
    {{/if}}

    {{#if successMessage}}
    <div class="gate-form-box" style="text-align:center">
        <p class="gate-success">{{successMessage}}</p>
        <a href="/login" class="gate-btn mt-3">&#x25B8; ENTER TOMMY'S CLUB</a>
    </div>
    {{else}}

    <div class="gate-form-box">
        <form method="POST" action="/register" class="gate-form" id="registerForm">
            <input type="hidden" name="_csrf" value="{{csrfToken}}">

            <!-- Anonymous identity picker -->
            <div class="gate-field">
                <label class="gate-label">Anonymous Identity</label>
                <div class="avatar-picker">
                    <label class="avatar-pick-option">
                        <input type="radio" name="default_avatar" value="m" checked>
                        <img src="/assets/avatar-anon-m.svg" alt="Shadow">
                    </label>
                    <label class="avatar-pick-option">
                        <input type="radio" name="default_avatar" value="f">
                        <img src="/assets/avatar-anon-f.svg" alt="Phantom">
                    </label>
                </div>
                <input type="hidden" name="avatar_url" id="avatarUrlInput" value="/assets/avatar-anon-m.svg">
            </div>

            <!-- Alias with random generator -->
            <div class="gate-field">
                <label class="gate-label">Alias <span style="color:var(--neon-cyan);cursor:pointer;margin-left:4px" id="genBtn" title="Randomise">&#x21BB;</span></label>
                <input type="text" name="username" id="usernameInput" class="gate-input"
                    value="{{username}}" placeholder="NeonGhost42" required autofocus>
            </div>

            <div class="gate-field">
                <label class="gate-label">Email</label>
                <input type="email" name="email" class="gate-input"
                    value="{{email}}" placeholder="anon@member.club" required>
            </div>

            <div class="gate-field">
                <label class="gate-label">Password</label>
                <input type="password" name="password" class="gate-input"
                    placeholder="Min. 6 characters" required minlength="6">
            </div>

            <div class="gate-field">
                <label class="gate-label">Confirm Password</label>
                <input type="password" name="password2" class="gate-input"
                    placeholder="••••••••" required>
            </div>

            <button type="submit" class="gate-btn">&#x25B8; JOIN TOMMY'S CLUB</button>
        </form>

        <p class="gate-switch mt-2">Already a member? <a href="/login">Enter</a></p>
    </div>

    {{/if}}
</div>

<script>
(function () {
    var adj  = ['Shadow','Cipher','Neon','Ghost','Phantom','Silent','Dark','Void','Echo','Mystic',
                'Stealth','Rogue','Onyx','Obsidian','Azure','Crimson','Silver','Veiled','Arcane','Lunar',
                'Ember','Frosted','Static','Hollow','Prism','Cobalt','Scarlet','Iron','Gilded','Ivory'];
    var noun = ['Wolf','Fox','Raven','Hawk','Serpent','Viper','Specter','Wraith','Oracle','Nexus',
                'Vector','Vertex','Nova','Drift','Pulse','Shade','Flux','Storm','Veil','Glitch',
                'Nomad','Cipher','Knight','Drifter','Signal','Myth','Edge','Shard','Crest','Bloom'];

    var genBtn = document.getElementById('genBtn');
    if (genBtn) {
        genBtn.addEventListener('click', function () {
            var a = adj[Math.floor(Math.random() * adj.length)];
            var n = noun[Math.floor(Math.random() * noun.length)];
            document.getElementById('usernameInput').value = a + n;
        });
    }

    document.querySelectorAll('input[name="default_avatar"]').forEach(function (radio) {
        radio.addEventListener('change', function () {
            document.getElementById('avatarUrlInput').value =
                this.value === 'f' ? '/assets/avatar-anon-f.svg' : '/assets/avatar-anon-m.svg';
        });
    });
})();
</script>
