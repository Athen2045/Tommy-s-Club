<div class="wf-row mb-3" style="gap:12px">
    <a href="/categories" class="wf-btn ghost sm">&#x2190;</a>
    <h1 class="wf-h2">New Channel</h1>
</div>

<div style="max-width:400px">
    {{#if errorMessage}}
    <div class="gate-error mb-3">{{errorMessage}}</div>
    {{/if}}

    <form method="POST" action="/categories/add" class="wf-stack" style="gap:16px">
        <input type="hidden" name="_csrf" value="{{csrfToken}}">
        <div class="gate-field">
            <label class="gate-label">Channel name</label>
            <input class="gate-input" id="category" name="category" type="text"
                placeholder="e.g. Technology" autofocus required>
            <span class="wf-mono mt-1" style="font-size:10px">A URL-friendly slug is generated automatically.</span>
        </div>
        <div class="wf-row" style="gap:10px">
            <button type="submit" class="gate-btn" style="width:auto;display:inline-block;padding:10px 28px">
                &#x25B8; Create
            </button>
            <a href="/categories" class="gate-btn ghost" style="width:auto;display:inline-block;padding:10px 22px">
                Cancel
            </a>
        </div>
    </form>
</div>
