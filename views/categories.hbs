<div class="admin-header">
    <div>
        <h1 class="admin-title">Channels</h1>
        <p class="admin-sub">Organise posts by topic</p>
    </div>
    {{#if session.user.isAdmin}}
    <a href="/categories/add" class="wf-btn cyan sm">&#x25B8; New Channel</a>
    {{/if}}
</div>

{{#if message}}
<div class="empty-state">
    <i class="bi bi-tags"></i>
    <h3>No channels yet</h3>
    {{#if session.user.isAdmin}}
    <a href="/categories/add" class="wf-btn mt-3" style="display:inline-block">&#x25B8; Create one</a>
    {{/if}}
</div>
{{else}}
<div class="wf-stack" style="gap:8px;max-width:600px">
    {{#each categories}}
    <div class="cat-row">
        <div>
            <a href="/blog?category={{id}}" class="cat-name">{{name}}</a>
            <div class="cat-slug">/{{slug}}</div>
        </div>
        <div style="display:flex;align-items:center;gap:12px">
            <span class="cat-count">{{postCount}} post{{#gt postCount 1}}s{{/gt}}</span>
            {{#if ../session.user.isAdmin}}
            <a href="/categories/delete/{{id}}"
                onclick="return confirm('Delete channel «{{name}}»?')"
                class="btn-delete" style="font-size:10px;padding:3px 8px">Del</a>
            {{/if}}
        </div>
    </div>
    {{/each}}
</div>
{{/if}}
