<div class="admin-header">
    <div>
        <h1 class="admin-title">Your Profile</h1>
        <p class="admin-sub">Update your public information</p>
    </div>
</div>

{{#if successMessage}}
<div class="gate-success mb-3" style="max-width:500px">{{successMessage}}</div>
{{/if}}
{{#if errorMessage}}
<div class="gate-error mb-3" style="max-width:500px">{{errorMessage}}</div>
{{/if}}

<div style="max-width:500px">
    <!-- Avatar preview -->
    <div class="profile-header mb-3" style="margin-bottom:20px">
        {{#if profile.avatar_url}}
        <img src="{{profile.avatar_url}}" class="profile-avatar" alt="avatar" id="avatarPreview">
        {{else}}
        <div class="profile-avatar-placeholder" id="avatarPreview">{{avatarInitial profile.username}}</div>
        {{/if}}
        <div>
            <div class="profile-username">{{profile.username}}</div>
            <div class="profile-since">{{session.user.email}}</div>
        </div>
    </div>

    <form method="POST" action="/profile" enctype="multipart/form-data" class="wf-stack" style="gap:16px">
        <div class="gate-field">
            <label class="gate-label">Username</label>
            <input type="text" class="gate-input" name="username"
                value="{{profile.username}}" required>
        </div>
        <div class="gate-field">
            <label class="gate-label">Bio</label>
            <textarea class="gate-input" name="bio" rows="3"
                placeholder="A little about you…">{{profile.bio}}</textarea>
        </div>
        <div class="gate-field">
            <label class="gate-label">Profile Picture</label>
            <input type="file" class="gate-input" name="avatar" accept="image/*"
                style="padding:6px 12px;cursor:pointer">
        </div>
        <button type="submit" class="gate-btn" style="width:auto;padding:10px 28px;display:inline-block">
            &#x25B8; Save Changes
        </button>
    </form>
</div>
