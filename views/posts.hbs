<div class="admin-page">
    <div class="container py-5">
        <div class="d-flex align-items-center justify-content-between mb-4">
            <div>
                <h1 class="admin-title">Posts</h1>
                <p class="text-muted mb-0">Manage all your blog posts</p>
            </div>
            <a href="/posts/add" class="btn btn-primary rounded-pill px-4">
                <i class="bi bi-plus-lg me-1"></i>New post
            </a>
        </div>

        <!-- Filter row -->
        <div class="admin-filters mb-4">
            <form method="GET" action="/posts" class="d-flex gap-2 flex-wrap">
                <select name="category" class="form-select w-auto">
                    <option value="">All categories</option>
                    {{#each categories}}
                    <option value="{{id}}">{{name}}</option>
                    {{/each}}
                </select>
                <input type="date" name="minDate" class="form-control w-auto" placeholder="From date">
                <button type="submit" class="btn btn-outline-secondary">Filter</button>
                <a href="/posts" class="btn btn-ghost-sm">Clear</a>
            </form>
        </div>

        {{#if message}}
        <div class="empty-state text-center py-5">
            <i class="bi bi-journal-x display-1 text-muted"></i>
            <h3 class="mt-3 text-muted">No posts found</h3>
            <a href="/posts/add" class="btn btn-primary rounded-pill mt-2">Write your first post</a>
        </div>
        {{else}}
        <div class="table-responsive admin-table-wrap">
            <table class="table table-hover admin-table mb-0">
                <thead>
                    <tr>
                        <th>Title</th>
                        {{#if session.user.isAdmin}}<th>Author</th>{{/if}}
                        <th>Category</th>
                        <th>Published</th>
                        <th>Date</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {{#each posts}}
                    <tr>
                        <td>
                            <a href="/blog/{{id}}" class="fw-medium text-decoration-none text-body">
                                {{title}}
                            </a>
                        </td>
                        {{#if ../session.user.isAdmin}}
                        <td class="text-muted small">{{profiles.username}}</td>
                        {{/if}}
                        <td>
                            {{#if categories}}
                            <span class="category-badge-sm">{{categories.name}}</span>
                            {{else}}
                            <span class="text-muted small">—</span>
                            {{/if}}
                        </td>
                        <td>
                            {{#if published}}
                            <span class="badge-live">Live</span>
                            {{else}}
                            <span class="badge-draft">Draft</span>
                            {{/if}}
                        </td>
                        <td class="text-muted small">{{formatDate created_at}}</td>
                        <td class="text-end">
                            <a href="/blog/{{id}}" class="btn btn-ghost-xs me-1" title="View">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a href="/posts/delete/{{id}}" class="btn btn-ghost-xs text-danger"
                                onclick="return confirm('Delete «{{title}}»?')" title="Delete">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
        {{/if}}
    </div>
</div>
