<!-- Hero -->
<div class="blog-hero">
    <div class="blog-hero-eyebrow">// members only &middot; bar open</div>
    <h1 class="blog-hero-title">THE STORIES</h1>
</div>

<!-- Category filter strip -->
{{#if categories.length}}
<div class="category-strip">
    <a href="/blog" class="category-chip {{#unless activeCategory}}active{{/unless}}">
        All Posts
    </a>
    {{#each categories}}
    <a href="/blog?category={{id}}" class="category-chip {{#equal id ../activeCategory}}active{{/equal}}">
        {{name}}
    </a>
    {{/each}}
</div>
{{/if}}

<!-- Posts grid -->
{{#if message}}
<div class="empty-state">
    <i class="bi bi-journal-x"></i>
    <h3>No posts yet</h3>
    <p>Check back soon for new content.</p>
    {{#if session.user}}
    <a href="/posts/add" class="wf-btn mt-3" style="display:inline-block">&#x25B8; Write the first post</a>
    {{/if}}
</div>
{{else}}

<div class="post-grid">

    {{! Featured post }}
    {{#if featuredPost}}
    <a href="/blog/{{featuredPost.id}}" class="post-card">
        {{#if featuredPost.feature_image}}
        <img src="{{featuredPost.feature_image}}" alt="{{featuredPost.title}}" class="post-card-img">
        {{/if}}
        {{#if featuredPost.categories}}
        <span class="post-card-cat">{{featuredPost.categories.name}}</span>
        {{/if}}
        <div class="post-card-title">{{featuredPost.title}}</div>
        <div class="post-card-excerpt">{{excerpt featuredPost.body 140}}</div>
        <div class="post-card-meta">
            <span>{{featuredPost.profiles.username}}</span>
            <span>&middot;</span>
            <span>{{timeAgo featuredPost.created_at}}</span>
            <span>&middot;</span>
            <span>{{readTime featuredPost.body}}</span>
        </div>
    </a>
    {{/if}}

    {{! Remaining posts }}
    {{#each recentPosts}}
    <a href="/blog/{{id}}" class="post-card">
        {{#if feature_image}}
        <img src="{{feature_image}}" alt="{{title}}" class="post-card-img">
        {{/if}}
        {{#if categories}}
        <span class="post-card-cat">{{categories.name}}</span>
        {{/if}}
        <div class="post-card-title">{{title}}</div>
        <div class="post-card-excerpt">{{excerpt body 110}}</div>
        <div class="post-card-meta">
            <span>{{profiles.username}}</span>
            <span>&middot;</span>
            <span>{{timeAgo created_at}}</span>
            <span>&middot;</span>
            <span>{{readTime body}}</span>
        </div>
    </a>
    {{/each}}

</div>
{{/if}}
