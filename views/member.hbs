<div class="profile-header">
    {{#if member.avatar_url}}
    <img src="{{member.avatar_url}}" alt="{{member.username}}'s profile picture" class="profile-avatar">
    {{else}}
    <div class="profile-avatar-placeholder">{{avatarInitial member.username}}</div>
    {{/if}}
    <div>
        <div class="profile-username">
            {{member.username}}
            {{#if member.isAdmin}}<img class="admin-verified-badge admin-verified-badge--profile" src="/assets/admin-verified.jpeg" alt="" aria-hidden="true"><span class="sr-only">Administrator</span>{{/if}}
        </div>
        <div class="profile-since">Member since {{formatDate member.created_at}} &middot; {{member.posts.length}} {{pluralize member.posts.length "post" "posts"}}</div>
        {{#if member.bio}}
        <div class="profile-bio">&ldquo;{{member.bio}}&rdquo;</div>
        {{/if}}
    </div>
</div>

<div class="wf-label" style="color:var(--neon-pink);margin-bottom:10px">
    POSTS BY {{member.username}}
</div>

{{#if member.posts.length}}
<div class="wf-stack" style="gap:8px">
    {{#each member.posts}}
    <a href="/blog/{{id}}" class="wf-box" style="display:flex;align-items:center;justify-content:space-between;padding:10px 14px;gap:12px;text-decoration:none;">
        <span style="font-family:var(--f-pixel);font-size:17px;color:var(--ink)">
            {{#if title}}{{title}}{{else}}{{excerpt body 60}}{{/if}}
        </span>
        <span class="wf-mono" style="flex-shrink:0">{{timeAgo created_at}}</span>
    </a>
    {{/each}}
</div>
{{else}}
<div class="empty-state">
    <p>No published posts yet.</p>
</div>
{{/if}}
