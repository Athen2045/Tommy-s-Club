<div class="admin-header">
    <div>
        <h1 class="admin-title">Your Profile</h1>
        <p class="admin-sub">Update your public information</p>
    </div>
</div>

{{#if successMessage}}
<div class="gate-success mb-3" style="max-width:500px">{{successMessage}}</div>
{{/if}}
{{#if errorMessage}}
<div class="gate-error mb-3" style="max-width:500px">{{errorMessage}}</div>
{{/if}}

<div style="max-width:500px">
    <!-- Avatar preview -->
    <div class="profile-header mb-3" style="margin-bottom:20px">
        {{#if profile.avatar_url}}
        <img src="{{profile.avatar_url}}" class="profile-avatar" alt="{{profile.username}}'s profile picture" id="avatarPreview">
        {{else}}
        <div class="profile-avatar-placeholder" id="avatarPreview">{{avatarInitial profile.username}}</div>
        {{/if}}
        <div>
            <div class="profile-username">{{profile.username}}</div>
            <div class="profile-since">Club member</div>
        </div>
    </div>

    <form method="POST" action="/profile" enctype="multipart/form-data" class="wf-stack profile-form" style="gap:16px">
        <input type="hidden" name="_csrf" value="{{csrfToken}}">
        <div class="gate-field">
            <label class="gate-label" for="profileUsername">Username</label>
            <input type="text" class="gate-input" id="profileUsername" name="username"
                value="{{profile.username}}" minlength="3" maxlength="32" pattern="[a-zA-Z0-9_]{3,32}" required>
            <span class="form-helper">Your unique public name. Use letters, numbers, or underscores.</span>
        </div>
        <div class="gate-field">
            <label class="gate-label" for="profileBio">Bio</label>
            <textarea class="gate-input" id="profileBio" name="bio" rows="3" maxlength="500"
                placeholder="A little about you…">{{profile.bio}}</textarea>
            <span class="form-helper">Up to 500 characters.</span>
        </div>
        <div class="gate-field">
            <label class="gate-label" for="profileAvatar">Profile picture</label>
            <div class="avatar-setup avatar-setup--profile">
                <div class="avatar-stage" aria-hidden="true">
                    <div class="avatar-stage-inner">
                        <img src="{{#if profile.avatar_url}}{{profile.avatar_url}}{{else}}/assets/avatar-anon-m.svg{{/if}}"
                            alt="" id="profileAvatarStageImage">
                    </div>
                </div>
                <div class="avatar-choice-grid" role="radiogroup" aria-label="Choose a default avatar">
                    <label class="avatar-choice">
                        <input type="radio" name="avatar_choice" value="m"
                            {{#if profile.avatar_url}}{{#equal profile.avatar_url "/assets/avatar-anon-m.svg"}}checked{{/equal}}{{else}}checked{{/if}}>
                        <span class="avatar-choice-visual"><img src="/assets/avatar-anon-m.svg" alt=""></span>
                        <span>Shadow</span>
                        <span class="avatar-choice-check" aria-hidden="true">&#x2713;</span>
                    </label>
                    <label class="avatar-choice">
                        <input type="radio" name="avatar_choice" value="f"
                            {{#equal profile.avatar_url "/assets/avatar-anon-f.svg"}}checked{{/equal}}>
                        <span class="avatar-choice-visual"><img src="/assets/avatar-anon-f.svg" alt=""></span>
                        <span>Phantom</span>
                        <span class="avatar-choice-check" aria-hidden="true">&#x2713;</span>
                    </label>
                </div>
                <input type="file" class="gate-input file-input" id="profileAvatar" name="avatar" accept="image/jpeg,image/png,image/gif,image/webp,image/avif">
                <span class="form-helper">Choose a JPEG, PNG, GIF, WebP, or AVIF image.</span>
            </div>
        </div>
        <button type="submit" class="gate-btn" style="width:auto;padding:10px 28px;display:inline-block">
            &#x25B8; Save Changes
        </button>
    </form>

</div>

<script>
(function () {
    var stage = document.getElementById('profileAvatarStageImage');
    if (!stage) return;
    document.querySelectorAll('input[name="avatar_choice"]').forEach(function (radio) {
        radio.addEventListener('change', function () {
            stage.src = this.value === 'f'
                ? '/assets/avatar-anon-f.svg'
                : '/assets/avatar-anon-m.svg';
        });
    });
})();
</script>
